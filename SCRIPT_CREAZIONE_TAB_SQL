create index idx_veicolo_status on public.veicolo(status);
create index idx_veicolo_fuel_type on public.veicolo(fuel_type);
create index idx_veicolo_transmission on public.veicolo(transmission);
create index idx_veicolo_body_style on public.veicolo(body_style);
create index idx_veicolo_is_active on public.veicolo(is_active);
create index idx_veicolo_published_to_meta on public.veicolo(published_to_meta);

-- =========================================================
-- INDICI TABELLA veicolo_media
-- =========================================================
create index idx_veicolo_media_id_veicolo on public.veicolo_media(id_veicolo);
create index idx_veicolo_media_principale on public.veicolo_media(principale);
create index idx_veicolo_media_ordine on public.veicolo_media(ordine);

-- =========================================================
-- INDICI TABELLA veicolo_optional
-- =========================================================
create index idx_veicolo_optional_id_veicolo on public.veicolo_optional(id_veicolo);
create index idx_veicolo_optional_nome on public.veicolo_optional(nome);

-- =========================================================
-- TRIGGER updated_at
-- =========================================================
create trigger trg_veicolo_updated_at
before update on public.veicolo
for each row
execute function public.handle_updated_at();

create trigger trg_veicolo_media_updated_at
before update on public.veicolo_media
for each row
execute function public.handle_updated_at();

create trigger trg_veicolo_optional_updated_at
before update on public.veicolo_optional
for each row
execute function public.handle_updated_at();